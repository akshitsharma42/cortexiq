{
  "name": "@cortexiq/ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
    "start": "uvicorn src.main:app --host 0.0.0.0 --port 8000",
    "lint": "ruff check src/",
    "format": "ruff format src/",
    "type-check": "mypy src/",
    "test": "pytest tests/",
    "clean": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; rm -rf .venv .mypy_cache .ruff_cache .pytest_cache"
  }
}
